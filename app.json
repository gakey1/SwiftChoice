{
  "expo": {
    "name": "SwiftChoice",
    "slug": "swiftchoice",
    "scheme": "swiftchoice",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.swiftchoice.app"
    },
    "android": {
      "package": "com.swiftchoice.app",
      "adaptiveIcon": {
        "backgroundColor": "#FAFAF7",
        "foregroundImage": "./assets/icon.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-font",
      "expo-secure-store",
      "expo-sqlite",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "SwiftChoice uses your location to find eating spots near you."
        }
      ]
    ]
  }
}
