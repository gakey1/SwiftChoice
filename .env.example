# Copy this file to .env and fill in the values from the Firebase console.
#
# Open the Firebase console at https://console.firebase.google.com,
# pick the SwiftChoice project, click the gear icon next to "Project
# Overview", scroll to "Your apps", and copy the web config values.
#
# The values are not secrets in the cryptographic sense (they ship with
# any client that uses Firebase), so do not treat them as credentials.
# Security comes from the Firestore rules at firestore.rules.

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
